{
	"extends": "@tsconfig/svelte/tsconfig.json",
	"compilerOptions": {
		"strict": true,
		"target": "ES2020",
		"noEmit": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"paths": {
			"$ts/*": ["./src/ts/*"],
			"$types/*": ["./src/types/*"],
			"$engine/*": ["./src/engine/*"]
		}
	},
	"include": [
		"src/svelte/Main.svelte",
		"src/types/**/*",
		"src/ts/**/*",
		"src/engine/**/*",
	],
	"exclude": ["node_modules/*", "__sapper__/*", "public/*"]
}
